#include "socfpga_cyclone5.dtsi"

/ {
    model = "Terasic DE1-SoC";
    compatible = "terasic,de1-soc", "altr,socfpga-cyclone5", "altr,socfpga";

    chosen {
        bootargs = "earlyprintk";
        stdout-path = "serial0:115200n8";
    };

    memory@0 {
        device_type = "memory";
        reg = <0x0 0x40000000>; /* 1GB HPS DDR memory */
    };

    aliases {
        ethernet0 = &gmac1;
    };

    regulator_3_3v: regulator {
        compatible = "regulator-fixed";
        regulator-name = "VCC3P3";
        regulator-min-microvolt = <3300000>;
        regulator-max-microvolt = <3300000>;
    };

    /* FPGA LEDs controlled via FPGA GPIO */
    leds {
        compatible = "gpio-leds";
        fpga_led0 { label = "fpga_led0"; gpios = <&gpio_fpga 0 0>; };
        fpga_led1 { label = "fpga_led1"; gpios = <&gpio_fpga 1 0>; };
        fpga_led2 { label = "fpga_led2"; gpios = <&gpio_fpga 2 0>; };
        fpga_led3 { label = "fpga_led3"; gpios = <&gpio_fpga 3 0>; };
        fpga_led4 { label = "fpga_led4"; gpios = <&gpio_fpga 4 0>; };
        fpga_led5 { label = "fpga_led5"; gpios = <&gpio_fpga 5 0>; };
        fpga_led6 { label = "fpga_led6"; gpios = <&gpio_fpga 6 0>; };
        fpga_led7 { label = "fpga_led7"; gpios = <&gpio_fpga 7 0>; };
        fpga_led8 { label = "fpga_led8"; gpios = <&gpio_fpga 8 0>; };
        fpga_led9 { label = "fpga_led9"; gpios = <&gpio_fpga 9 0>; };
    };

    /* Extending the soc node from dtsi directly */
    soc {
        gpio_fpga: gpio@ff200070 {
            compatible = "altr,pio-1.0";
            reg = <0xff200070 0x10>;
            altr,ngpio = <10>;
            #gpio-cells = <2>;
            gpio-controller;
            status = "okay";
        };
    };
};

/* Enables HPS-to-FPGA bridge */
&fpga_bridge0 {
    status = "okay";
};

&gmac1 {
    status = "okay";
    phy-mode = "rgmii";
    rxd0-skew-ps = <0>;
    rxd1-skew-ps = <0>;
    rxd2-skew-ps = <0>;
    rxd3-skew-ps = <0>;
    txen-skew-ps = <0>;
    txc-skew-ps = <2600>;
    rxdv-skew-ps = <0>;
    rxc-skew-ps = <2000>;
};

&gpio0 { status = "okay"; };
&gpio1 {
    status = "okay";
    /* Selects I2C path between HPS and FPGA */
    i2c_mux_select: i2c-mux-select {
        gpio-hog;
        gpios = <19 0>;
        output-high;
        line-name = "i2c-hps-to-fpga";
    };
};
&gpio2 { status = "okay"; };

/* HPS I2C controller used for external devices */
&i2c2 {
    status = "okay";
    clock-frequency = <100000>;
    /* Joystick connected via I2C GPIO expander */
    joystick@70 {
        compatible = "nxp,pca9538";
        reg = <0x70>;
        gpio-controller;
        #gpio-cells = <2>;
        status = "okay";
    };
};

&mmc0 {
    vmmc-supply = <&regulator_3_3v>;
    vqmmc-supply = <&regulator_3_3v>;
    status = "okay";
};

&usb1 {
    status = "okay";
};